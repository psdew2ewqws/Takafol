generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Charity Organizations (admin-managed) ──
model Charity {
  id            String   @id @default(uuid())
  name          String
  nameAr        String?  @map("name_ar")
  description   String?
  descriptionAr String?  @map("description_ar")
  logoUrl       String?  @map("logo_url")
  isVerified    Boolean  @default(false) @map("is_verified")
  contactEmail  String?  @map("contact_email")
  contactPhone  String?  @map("contact_phone")
  website       String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  programs  VolunteerProgram[]
  donations ZakatDonation[]

  @@map("charities")
}

// ── Volunteering Programs ──
model VolunteerProgram {
  id                String   @id @default(uuid())
  charityId         String   @map("charity_id")
  title             String
  titleAr           String?  @map("title_ar")
  description       String?
  descriptionAr     String?  @map("description_ar")
  location          String?
  district          String?
  maxVolunteers     Int?     @map("max_volunteers")
  currentVolunteers Int      @default(0) @map("current_volunteers")
  startDate         DateTime? @map("start_date")
  endDate           DateTime? @map("end_date")
  status            String   @default("open") // open | full | completed | cancelled
  createdAt         DateTime @default(now()) @map("created_at")

  charity      Charity                @relation(fields: [charityId], references: [id], onDelete: Cascade)
  applications VolunteerApplication[]

  @@map("volunteer_programs")
}

// ── Volunteer Applications ──
model VolunteerApplication {
  id        String   @id @default(uuid())
  programId String   @map("program_id")
  userId    String   @map("user_id")
  userName  String?  @map("user_name")
  status    String   @default("pending") // pending | accepted | rejected | completed
  appliedAt DateTime @default(now()) @map("applied_at")

  program VolunteerProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, userId])
  @@map("volunteer_applications")
}

// ── Zakat Donations ──
model ZakatDonation {
  id            String   @id @default(uuid())
  donorId       String   @map("donor_id")
  donorName     String?  @map("donor_name")
  charityId     String   @map("charity_id")
  amount        Float
  currency      String   @default("JOD")
  receiptNumber String?  @map("receipt_number")
  txHash        String?  @map("tx_hash")
  explorerUrl   String?  @map("explorer_url")
  status        String   @default("confirmed") // pending | confirmed | failed
  createdAt     DateTime @default(now()) @map("created_at")

  charity Charity @relation(fields: [charityId], references: [id])

  @@map("zakat_donations")
}

// ── Impact / Leaderboard ──
model UserImpact {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  userName       String   @map("user_name")
  avatarUrl      String?  @map("avatar_url")
  impactScore    Int      @default(0) @map("impact_score")
  tasksCompleted Int      @default(0) @map("tasks_completed")
  totalDonated   Float    @default(0) @map("total_donated")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("user_impacts")
}
