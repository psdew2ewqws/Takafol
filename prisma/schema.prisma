generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum PostType {
  OFFER
  REQUEST
}

enum PostStatus {
  ACTIVE
  MATCHED
  COMPLETED
  EXPIRED
  CANCELLED
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum VolunteerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

// ─── NextAuth Tables ─────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── User ────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String?  @unique
  emailVerified  DateTime? @map("email_verified")
  password       String?
  image          String?
  phone          String?
  bio            String?  @db.Text
  districtId     String?  @map("district_id")
  impactScore    Int      @default(0) @map("impact_score")
  tasksCompleted Int      @default(0) @map("tasks_completed")
  averageRating  Float    @default(0) @map("average_rating")
  isBanned       Boolean  @default(false) @map("is_banned")
  role           UserRole @default(USER)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  district District? @relation(fields: [districtId], references: [id])

  accounts              Account[]
  sessions              Session[]
  posts                 Post[]
  giverConnections      Connection[]          @relation("GiverConnections")
  requesterConnections  Connection[]          @relation("RequesterConnections")
  messages              Message[]
  volunteerApplications VolunteerApplication[]
  zakatDonations        ZakatDonation[]
  reportsFiled          Report[]              @relation("ReportsFiled")
  reportsReceived       Report[]              @relation("ReportsReceived")
  pushSubscriptions     PushSubscription[]
  notificationsSent     NotificationLog[]
  userChallenges        UserChallenge[]
  pointTransactions     PointTransaction[]
  userBadges            UserBadge[]
  streak                Streak?
  level                 Int      @default(1)

  @@map("users")
}

// ─── Category ────────────────────────────────────────────

model Category {
  id      String @id
  nameEn  String @map("name_en")
  nameAr  String @map("name_ar")
  icon    String
  posts   Post[]

  @@map("categories")
}

// ─── District ────────────────────────────────────────────

model District {
  id     String @id
  nameEn String @map("name_en")
  nameAr String @map("name_ar")
  users  User[]
  posts  Post[]

  @@map("districts")
}

// ─── Post ────────────────────────────────────────────────

model Post {
  id          String     @id @default(cuid())
  type        PostType
  description String     @db.Text
  categoryId  String     @map("category_id")
  districtId  String     @map("district_id")
  urgency     UrgencyLevel @default(MEDIUM)
  status      PostStatus @default(ACTIVE)
  userId      String     @map("user_id")

  // AI moderation fields
  aiModerated   Boolean  @default(false) @map("ai_moderated")
  aiScore       Float?   @map("ai_score")
  aiSummary     String?  @map("ai_summary") @db.Text

  // Image (Cloudinary URL)
  imageUrl  String?  @map("image_url")

  // Location coordinates (from browser geolocation)
  latitude  Float?
  longitude Float?

  // Blockchain verification
  blockchainTx  String?  @map("blockchain_tx")
  blockchainVerified Boolean @default(false) @map("blockchain_verified")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  expiresAt DateTime? @map("expires_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category    @relation(fields: [categoryId], references: [id])
  district    District    @relation(fields: [districtId], references: [id])
  connections Connection[]

  @@index([type, status])
  @@index([categoryId])
  @@index([districtId])
  @@index([urgency])
  @@index([userId])
  @@map("posts")
}

// ─── Connection ──────────────────────────────────────────

model Connection {
  id          String           @id @default(cuid())
  postId      String           @map("post_id")
  giverId     String           @map("giver_id")
  requesterId String           @map("requester_id")
  status      ConnectionStatus @default(PENDING)

  // Proof of completion
  proofImageUrl  String? @map("proof_image_url")
  proofNote      String? @map("proof_note") @db.Text
  completedAt    DateTime? @map("completed_at")

  // Ratings
  giverRating      Int?    @map("giver_rating")
  requesterRating  Int?    @map("requester_rating")
  giverReview      String? @map("giver_review") @db.Text
  requesterReview  String? @map("requester_review") @db.Text

  // Blockchain verification
  blockchainTx       String?  @map("blockchain_tx")
  completionTx       String?  @map("completion_tx")
  ratingTx           String?  @map("rating_tx")
  blockchainVerified Boolean  @default(false) @map("blockchain_verified")

  // Impact points
  giverPoints     Int @default(0) @map("giver_points")
  requesterPoints Int @default(0) @map("requester_points")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  giver     User      @relation("GiverConnections", fields: [giverId], references: [id])
  requester User      @relation("RequesterConnections", fields: [requesterId], references: [id])
  messages  Message[]

  @@index([postId])
  @@index([giverId])
  @@index([requesterId])
  @@index([status])
  @@map("connections")
}

// ─── Message ─────────────────────────────────────────────

model Message {
  id           String  @id @default(cuid())
  connectionId String  @map("connection_id")
  senderId     String  @map("sender_id")
  content      String  @db.Text
  isRead       Boolean @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  sender     User       @relation(fields: [senderId], references: [id])

  @@index([connectionId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// ─── Charity ─────────────────────────────────────────────

model Charity {
  id             String  @id @default(cuid())
  name           String
  nameAr         String  @map("name_ar")
  description    String? @db.Text
  descriptionAr  String? @map("description_ar") @db.Text
  logoUrl        String? @map("logo_url")
  website        String?
  cliqAlias      String? @map("cliq_alias")
  iban           String?
  isVerified     Boolean @default(false) @map("is_verified")
  isActive       Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  volunteerPrograms VolunteerProgram[]
  zakatDonations    ZakatDonation[]

  @@map("charities")
}

// ─── Volunteer Program ───────────────────────────────────

model VolunteerProgram {
  id          String  @id @default(cuid())
  charityId   String  @map("charity_id")
  title       String
  titleAr     String  @map("title_ar")
  description String? @db.Text
  descriptionAr String? @map("description_ar") @db.Text
  capacity    Int     @default(0)
  enrolled    Int     @default(0)
  isActive    Boolean @default(true) @map("is_active")

  startsAt DateTime? @map("starts_at")
  endsAt   DateTime? @map("ends_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  charity      Charity                @relation(fields: [charityId], references: [id], onDelete: Cascade)
  applications VolunteerApplication[]

  @@index([charityId])
  @@map("volunteer_programs")
}

// ─── Volunteer Application ───────────────────────────────

model VolunteerApplication {
  id        String                     @id @default(cuid())
  userId    String                     @map("user_id")
  programId String                     @map("program_id")
  status    VolunteerApplicationStatus @default(PENDING)
  fullName  String?                    @map("full_name")
  phone     String?
  note      String?                    @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  program VolunteerProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@map("volunteer_applications")
}

// ─── Zakat Donation ──────────────────────────────────────

model ZakatDonation {
  id        String  @id @default(cuid())
  donorId   String  @map("donor_id")
  charityId String  @map("charity_id")
  amount    Float
  currency  String  @default("JOD")
  receiptUrl String? @map("receipt_url")

  // Blockchain verification
  blockchainTx       String?  @map("blockchain_tx")
  blockchainVerified Boolean  @default(false) @map("blockchain_verified")

  createdAt DateTime @default(now()) @map("created_at")

  donor   User    @relation(fields: [donorId], references: [id])
  charity Charity @relation(fields: [charityId], references: [id])

  @@index([donorId])
  @@index([charityId])
  @@map("zakat_donations")
}

// ─── Report ──────────────────────────────────────────────

model Report {
  id             String       @id @default(cuid())
  reporterId     String       @map("reporter_id")
  reportedUserId String       @map("reported_user_id")
  reason         String       @db.Text
  status         ReportStatus @default(PENDING)
  adminNote      String?      @map("admin_note") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reporter     User @relation("ReportsFiled", fields: [reporterId], references: [id])
  reportedUser User @relation("ReportsReceived", fields: [reportedUserId], references: [id])

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
  @@map("reports")
}

// ─── Task (Volunteering) ────────────────────────────────

model Task {
  id                String   @id @default(cuid())
  creatorId         String   @map("creator_id")
  creatorName       String   @default("Anonymous") @map("creator_name")
  title             String
  description       String   @db.Text
  category          String
  impactLetter      String?  @map("impact_letter") @db.Text
  maxVolunteers     Int      @map("max_volunteers")
  currentVolunteers Int      @default(0) @map("current_volunteers")
  status            String   @default("pending") // pending, approved, in_progress, completed, rejected
  location          String?
  district          String?
  txHash            String?  @map("tx_hash")
  explorerUrl       String?  @map("explorer_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  applications TaskApplication[]

  @@index([creatorId])
  @@index([status])
  @@index([category])
  @@map("tasks")
}

// ─── Task Application ───────────────────────────────────

model TaskApplication {
  id              String  @id @default(cuid())
  taskId          String  @map("task_id")
  volunteerId     String  @map("volunteer_id")
  volunteerName   String  @map("volunteer_name")
  status          String  @default("pending") // pending, accepted, rejected, completed
  proofPhotoBase64 String? @map("proof_photo_base64") @db.Text
  proofHash       String? @map("proof_hash")
  proofTxHash     String? @map("proof_tx_hash")
  proofExplorerUrl String? @map("proof_explorer_url")
  completedAt     DateTime? @map("completed_at")

  appliedAt DateTime @default(now()) @map("applied_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, volunteerId])
  @@index([taskId])
  @@index([volunteerId])
  @@map("task_applications")
}

// ─── Certificate ────────────────────────────────────────

model Certificate {
  id              String   @id @default(cuid())
  recipientId     String   @map("recipient_id")
  recipientName   String   @map("recipient_name")
  connectionId    String?  @map("connection_id")
  taskId          String?  @map("task_id")
  title           String
  description     String   @db.Text
  category        String
  certHash        String   @map("cert_hash")
  blockchainTx    String?  @map("blockchain_tx")
  explorerUrl     String?  @map("explorer_url")
  issuedAt        DateTime @default(now()) @map("issued_at")

  @@index([recipientId])
  @@index([certHash])
  @@map("certificates")
}

// ─── User Impact (Leaderboard) ──────────────────────────

model UserImpact {
  id             String  @id @default(cuid())
  userId         String  @unique @map("user_id")
  userName       String  @default("Anonymous") @map("user_name")
  avatarUrl      String? @map("avatar_url")
  impactScore    Int     @default(0) @map("impact_score")
  tasksCompleted Int     @default(0) @map("tasks_completed")
  totalDonated   Float   @default(0) @map("total_donated")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_impacts")
}

// ─── Push Subscription ─────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  endpoint  String   @unique
  p256dhKey String   @map("p256dh_key")
  authKey   String   @map("auth_key")
  userAgent String?  @map("user_agent")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isActive])
  @@map("push_subscriptions")
}

// ─── Notification Log ───────────────────────────────────

model NotificationLog {
  id             String    @id @default(cuid())
  titleEn        String    @map("title_en")
  titleAr        String    @map("title_ar")
  bodyEn         String    @map("body_en")
  bodyAr         String    @map("body_ar")
  iconUrl        String?   @map("icon_url")
  linkUrl        String?   @map("link_url")
  targetType     String    @default("ALL") @map("target_type")
  recipientCount Int       @default(0) @map("recipient_count")
  sentAt         DateTime  @default(now()) @map("sent_at")
  scheduledFor   DateTime? @map("scheduled_for")
  status         String    @default("SENT")
  sentById       String    @map("sent_by_id")

  sentBy User @relation(fields: [sentById], references: [id])

  @@index([sentById])
  @@index([sentAt])
  @@map("notification_logs")
}

// ─── Daily Challenge ────────────────────────────────────

model DailyChallenge {
  id            String   @id @default(cuid())
  date          DateTime @unique @db.Date
  titleEn       String   @map("title_en")
  titleAr       String   @map("title_ar")
  descriptionEn String   @map("description_en") @db.Text
  descriptionAr String   @map("description_ar") @db.Text
  category      String
  actionType    String   @map("action_type")
  actionTarget  String?  @map("action_target")
  points        Int
  iconEmoji     String   @default("trophy") @map("icon_emoji")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  userChallenges UserChallenge[]

  @@index([date])
  @@index([isActive])
  @@map("daily_challenges")
}

// ─── User Challenge ─────────────────────────────────────

model UserChallenge {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  challengeId   String    @map("challenge_id")
  status        String    @default("PENDING")
  completedAt   DateTime? @map("completed_at")
  pointsAwarded Int       @default(0) @map("points_awarded")
  proofType     String?   @map("proof_type")
  proofId       String?   @map("proof_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
  @@index([status])
  @@map("user_challenges")
}

// ─── Point Transaction (Audit Log) ─────────────────────

model PointTransaction {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  points    Int
  metadata  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action])
  @@map("point_transactions")
}

// ─── Badge Definition ──────────────────────────────────

model Badge {
  id          String @id @default(cuid())
  key         String @unique
  nameEn      String @map("name_en")
  nameAr      String @map("name_ar")
  descEn      String @map("desc_en") @db.Text
  descAr      String @map("desc_ar") @db.Text
  category    String
  icon        String
  threshold   Int    @default(1)
  createdAt   DateTime @default(now()) @map("created_at")

  userBadges UserBadge[]

  @@index([category])
  @@map("badges")
}

// ─── User Badge (Earned) ───────────────────────────────

model UserBadge {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  badgeId  String   @map("badge_id")
  earnedAt DateTime @default(now()) @map("earned_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

// ─── Streak Tracking ───────────────────────────────────

model Streak {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  currentStreak  Int      @default(0) @map("current_streak")
  longestStreak  Int      @default(0) @map("longest_streak")
  lastActionDate DateTime? @map("last_action_date") @db.Date
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}
